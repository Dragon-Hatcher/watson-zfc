### The Ordered Pair

An ordered pair (a, b) is a set composed of a singleton {a} and a pair {a, b}. We can use ordered pairs to enforce certain structure on sets.
notation ordered_pair
    term ::= "⟨" term ", " term "⟩"
end

definition
    ⟨a, b⟩ := {{a}, {a, b}}
end

The proof follows from the pairing axiom and the definition of the ordered pair.

-- TODO: do we need this?
theorem opair.def [a b : term] :
    |- ∀x, x ∈ ⟨a, b⟩ ↔ (x = {a} ∨ x = {a, b})
proof
    suffices ∀x, x ∈ {{a}, {a, b}} ↔ (x = {a} ∨ x = {a, b});
    follows ∃c, ∀x, x ∈ c ↔ (x = {a} ∨ x = {a, b})      by zfc.pairing;
    thus ∀x, x ∈ {{a}, {a, b}} ↔ (x = {a} ∨ x = {a, b}) by uncomp.def [_ = {a} ∨ _ = {a, b}];
qed

theorem opair.unfold [a b : term] :
    |- ⟨a, b⟩ = {{a}, {a, b}}
proof
    done by eq.refl [⟨a, b⟩]
qed

Lets prove some basic properties of ordered pairs

theorem opair.union [a b : term] :
    |- ⋃⟨a, b⟩ = {a, b}
proof
    suffices ⋃{{a}, {a, b}} = {a, b};
    thus ∀x, x ∈ {a, b} ↔ (x = a ∨ x = b) by pair.def;
    thus ∀x, x ∈ ⋃{{a}, {a, b}} ↔ (x ∈ {a} ∨ x ∈ {a, b}) by union.def [{a}] [{a, b}];
    hence ∀x, (x = a ∨ (x = a ∨ x = b)) ↔ (x = a ∨ x = b) logically;
    follows ∀x, (x ∈ {a} ∨ x ∈ {a, b}) ↔ (x = a ∨ (x = a ∨ x = b)) by singleton.def, pair.def;
    done by zfc.extensionality
qed

theorem opair.inter [a b : term] :
    |- ⋂⟨a, b⟩ = {a}
proof
    suffices ⋂{{a}, {a, b}} = {a};
    thus ∀x, x ∈ {a} ↔ x = a by singleton.def;
    thus ∀x, x ∈ {a, b} ↔ (x = a ∨ x = b) by pair.def;
    thus ∀x, x ∈ ⋂{{a}, {a, b}} ↔ (x ∈ {a} ∧ x ∈ {a, b}) by inter.def [{a}] [{a, b}];
    hence ∀x, (x = a ∧ (x = a ∨ x = b)) ↔ x = a logically;
    thus ∀x, x ∈ ⋂{{a}, {a, b}} ↔ x ∈ {a} by singleton.def;
    follows ⋂{{a}, {a, b}} = {a} by zfc.extensionality;
qed

Next, we define a function which gives us the first element of an ordered pair. We define this function somewhat broadly, but it allows for an easy proof.

definition
    π₁(a) := ⋃⋂a
end

The proof follows from the definition of the ordered pair and many of the intersection properties we've shown.

theorem opair_first.def [a b : term] :
    |- π₁(⟨a, b⟩) = a
proof
    hence ⋂⟨a, b⟩ = {a} by opair.inter;
    thus ⋃{a} = a by big_union.singleton;
    hence ⋃⋂⟨a, b⟩ = a logically;
qed

Naturally, we now define the second element of an ordered pair.

definition
    π₂(a) := ⋃{x ∈ ⋃a | ⋃a ≠ ⋂a → x ∉ ⋂a}
end

This proof follows simply from the definition of the ordered pair and the properties of unions and intersections.

theorem opair_second.def [a b : term] :
    |- π₂(⟨a, b⟩) = b
proof
    suffices ⋃{x ∈ ⋃⟨a, b⟩ | ⋃⟨a, b⟩ ≠ ⋂⟨a, b⟩ → x ∉ ⋂⟨a, b⟩} = b;
    follows ⋃⟨a, b⟩ = {a, b} by opair.union;
    follows ⋂⟨a, b⟩ = {a}    by opair.inter;
    -- We can simplify our goal with our known facts for the union and intersection
    hence ⋃{x ∈ ⋃⟨a, b⟩ | ⋃⟨a, b⟩ ≠ ⋂⟨a, b⟩ → x ∉ ⋂⟨a, b⟩}
        = ⋃{x ∈ {a, b} | {a, b} ≠ {a} → x ∉ {a}} logically;
    thus ∀x, x ∈ {a, b} ↔ (x = a ∨ x = b) by pair.def;
    follows ∀x, x ∈ {a} ↔ x = a by singleton.def;
    follows {a, b} ≠ {a} ↔ a ≠ b logically;
    hence ∀x, ((x = a ∨ x = b) ∧ (a ≠ b → x ∉ {a})) ↔ x = b logically;
    thus ∀x, x ∈ {x ∈ {a, b} | {a, b} ≠ {a} → x ∉ {a}} ↔ x = b by zfc.extensionality;
    hence ∀x, x = b ↔ x ∈ {b} by singleton.def;
    follows ∀x, x ∈ {x ∈ {a, b} | {a, b} ≠ {a} → x ∉ {a}} ↔ x ∈ {b} logically;
    follows {x ∈ {a, b} | {a, b} ≠ {a} → x ∉ {a}} = {b} by zfc.extensionality;
    -- so π₂(⟨a, b⟩) = ⋃{b} = b
    hence ⋃{x ∈ {a, b} | {a, b} ≠ {a} → x ∉ {a}} = ⋃{b} logically;
    done by big_union.singleton
qed

Finally, we show that two ordered pairs are equal iff their first and second elements are equal.

theorem opair.eq [a b c d : term] :
    |- ⟨a, b⟩ = ⟨c, d⟩ ↔ (a = c ∧ b = d)
proof
    hence ⟨a, b⟩ = ⟨c, d⟩ → π₁(⟨a, b⟩) = π₁(⟨c, d⟩) by zfc.extensionality;
    follows π₁(⟨a, b⟩) = π₁(⟨c, d⟩) ↔ a = c by opair_first.def;
    follows ⟨a, b⟩ = ⟨c, d⟩ → π₂(⟨a, b⟩) = π₂(⟨c, d⟩) by zfc.extensionality;
    follows π₂(⟨a, b⟩) = π₂(⟨c, d⟩) ↔ b = d by opair_second.def;
    -- suffices ⟨a, b⟩ = ⟨c, d⟩ ↔ (a = c ∧ b = d);
    hence ⟨a, b⟩ = ⟨c, d⟩ → (a = c ∧ b = d) logically;
    hence (a = c ∧ b = d) → ⟨a, b⟩ = ⟨c, d⟩ logically;
    done logically
qed

### The Cartesian Product

The Cartesian product of two sets is the set of all ordered pairs formed from
the elements of those sets. A double powerset is sufficient to make a superset
of the Cartesian product from which we can then restrict to get the required
set.

notation product
    term (350) ::= term " × " term
end

definition
    A × B := {x ∈ 𝒫(𝒫(A ∪ B)) | ∃a ∈ A, ∃b ∈ B, x = ⟨a, b⟩}
end

The difficult task is to prove that this gives us every possible ordered pair.

theorem cart_prod.def [A B : term] :
    |- ∀x, x ∈ A × B ↔ ∃a ∈ A, ∃b ∈ B, x = ⟨a, b⟩
proof
    arbitrary x;

    -- remember the definition of A × B. (specifically have Vampire remember it)
    follows A × B = {x ∈ 𝒫(𝒫(A ∪ B)) | ∃a ∈ A, ∃b ∈ B, x = ⟨a, b⟩}
        by eq.refl [A × B];

    -- the forward direction is pretty simple. it just comes directly from the
    -- definition of restricted comprehension.
    assume x ∈ A × B then ∃a ∈ A, ∃b ∈ B, x = ⟨a, b⟩ logically;

    -- the other direction is harder. it follows quickly that x satisfies the
    -- comprehension condition, but it is a little more work to show it is in
    -- the double powerset.
    assume ∃a ∈ A, ∃b ∈ B, x = ⟨a, b⟩ then x ∈ A × B as
        obtain a st a ∈ A and b st b ∈ B ∧ x = ⟨a, b⟩ logically;
        follows x = {{a}, {a, b}} by_def x = ⟨a, b⟩;

        -- we already have that x is a pair so we just need to prove it is in the powerset
        suffices x ∈ 𝒫(𝒫(A ∪ B)) ∧ (∃a ∈ A, ∃b ∈ B, x = ⟨a, b⟩) logically;
        suffices x ∈ 𝒫(𝒫(A ∪ B)) given x = ⟨a, b⟩;

        follows a ∈ A ∪ B ∧ b ∈ A ∪ B    by union.def given a ∈ A and b ∈ B;
        thus  {a}          ∈   𝒫(A ∪ B)  by powset.singleton_in;
        thus       {a, b}  ∈   𝒫(A ∪ B)  by powset.pair_in;
        thus {{a}, {a, b}} ∈ 𝒫(𝒫(A ∪ B)) by powset.pair_in;
        thus             x ∈ 𝒫(𝒫(A ∪ B)) given x = {{a}, {a, b}};
    ;

    done logically
qed

Next, we prove a useful result relating the cartesian product of sets to their subsets.

lemma cart_prod.sub [A B C D : term] : (A ⊆ C) (B ⊆ D)
    |- A × B ⊆ C × D
proof
    suffices ∀x ∈ A × B, x ∈ C × D;
    arbitrary x;
    assume x ∈ A × B then x ∈ C × D as
        obtain a st a ∈ A and b st b ∈ B ∧ x = ⟨a, b⟩ by cart_prod.def;
        follows a ∈ C by sub.def given A ⊆ C;
        follows b ∈ D by sub.def given B ⊆ D;
        done by cart_prod.def
        ;
    done logically
qed


We can define the set of binary relations between two sets as the powerset of 
the Cartesian product of those two sets. Conceptually, if $R$ is a relation
between $A$ and $B$ then it is the set of all pairs $(a, b)$ where $a$ and $b$
are related by $R$.

notation term.with_term_term
    term (1000) ::= @name "(" term ", " term ")"
end

definition
    Rel(A, B) := 𝒫(A × B)
end

theorem rel_on.def [A B : term] :
    |- ∀R, R ∈ Rel(A, B) ↔ R ⊆ A × B
proof
    follows Rel(A, B) = 𝒫(A × B) by eq.refl [Rel(A, B)];
    done by powset.def
qed


For a relation we have the notions of the domain and range which are the sets
of the first element of each pair and the second element of each pair, respectively.

definition
    dom(R) := {π₁(x) | x ∈ R}
end

definition
    ran(R) := {π₂(x) | x ∈ R}
end

We can prove the following using the set map definition.

theorem dom.def [R : term] :
    |- ∀x, x ∈ dom(R) ↔ ∃y ∈ R, x = π₁(y)
proof
    suffices ∀x, x ∈ {π₁(z) | z ∈ R} ↔ ∃y ∈ R, x = π₁(y);
    thus ∀x, x ∈ {π₁(z) | z ∈ R} ↔ (∃z, z ∈ R ∧ x = π₁(z)) by set_map.def [π₁(_)] [R];
    done logically
qed

theorem ran.def [R : term] :
    |- ∀x, x ∈ ran(R) ↔ ∃y ∈ R, x = π₂(y)
proof
    suffices ∀x, x ∈ {π₂(z) | z ∈ R} ↔ ∃y ∈ R, x = π₂(y);
    thus ∀x, x ∈ {π₂(z) | z ∈ R} ↔ (∃z, z ∈ R ∧ x = π₂(z)) by set_map.def [π₂(_)] [R];
    done logically
qed

We can also have the notion of being a relation without having to know the
exact domain and range.

notation postfix_pred
    sentence ::= term " : " @name
end

definition
    R : Rel := R ∈ Rel(dom(R), ran(R))
end

theorem rel.def [R : term] :
    |- R : Rel ↔ R ∈ Rel(dom(R), ran(R))
proof
    done by iff.refl [R : Rel]
qed

The following result can be proved using the different relation definitions as well as the definition of the domain and range.

theorem rel.is_rel_on [R : term] :
    |- R : Rel ↔ ∃A, ∃B, R ∈ Rel(A, B)
proof
    -- (→)
    assume R : Rel then ∃A, ∃B, R ∈ Rel(A, B) as
        follows R ∈ Rel(dom(R), ran(R)) by rel.def;
        done logically;
    -- (←)
    assume ∃A, ∃B, R ∈ Rel(A, B) then R : Rel as
        -- We can fix A and B with our assumption
        obtain A st ∃B, R ∈ Rel(A, B) logically;
        obtain B st R ∈ Rel(A, B) logically;
        follows R ⊆ A × B by rel_on.def;
        suffices R ∈ Rel(dom(R), ran(R)) by rel.def;
        suffices R ⊆ dom(R) × ran(R) by rel_on.def;
        suffices ∀x, x ∈ R → x ∈ dom(R) × ran(R) by sub.def;
        arbitrary x;
        assume x ∈ R then x ∈ dom(R) × ran(R) as
            follows ∀y, y ∈ R → y ∈ A × B by sub.def given R ⊆ A × B;
            follows x ∈ A × B logically;
            -- As x is an ordered pair in A × B, we know specifically that there is an a and b which make up the ordered pair x
            obtain a st a ∈ A and b st b ∈ B ∧ x = ⟨a, b⟩ by cart_prod.def;
            -- TODO: This (2 next lines) should not be something we have to prove
            follows π₁(x) = a by opair_first.def given x = ⟨a, b⟩;
            follows π₂(x) = b by opair_second.def given x = ⟨a, b⟩;
            -- The first and second coordinates of x are by definition in the domain and range of R
            thus π₁(x) ∈ dom(R) by dom.def given x ∈ R;
            thus π₂(x) ∈ ran(R) by ran.def given x ∈ R;
            done by cart_prod.def;
        ;
    done logically
qed

We can show this fact in a similar manner to the previous proof, additionally making use of our cartesian product subset lemma.
theorem rel_on.is_rel [R A B : term] :
    |- R ∈ Rel(A, B) ↔ (R : Rel ∧ dom(R) ⊆ A ∧ ran(R) ⊆ B)
proof
    -- If R is a relation, then its a relation between sets
    follows R : Rel ↔ ∃C, ∃D, R ∈ Rel(C, D) by rel.is_rel_on;
    suffices R ∈ Rel(A, B) ↔ ((∃C, ∃D, R ∈ Rel(C, D)) ∧ dom(R) ⊆ A ∧ ran(R) ⊆ B) logically;
    -- (→)
    assume R ∈ Rel(A, B) then ((∃C, ∃D, R ∈ Rel(C, D)) ∧ dom(R) ⊆ A ∧ ran(R) ⊆ B) as
        -- Really we just have to show that dom(R) ⊆ A and ran(R) ⊆ B as the first proposition is the same as our assumption
        hence R ⊆ A × B by rel_on.def;
        hence ∃C, ∃D, R ⊆ C × D logically;
        follows ∃C, ∃D, R ∈ Rel(C, D) by rel_on.def;
        suffices dom(R) ⊆ A ∧ ran(R) ⊆ B logically;
        suffices (∀x ∈ dom(R), x ∈ A) ∧ (∀y ∈ ran(R), y ∈ B) by sub.def;
        suffices (∀x, x ∈ dom(R) → x ∈ A) ∧ (∀y, y ∈ ran(R) → y ∈ B) logically;
        -- Similarly to the last proof, we want to show the statement holds for an arbitrary element
        hence (∀x, x ∈ dom(R) → x ∈ A) as
            arbitrary x;
            assume x ∈ dom(R) then x ∈ A as
                obtain z st z ∈ R ∧ x = π₁(z) by dom.def;
                follows z ∈ A × B by sub.def given R ⊆ A × B;
                obtain a st a ∈ A and b st b ∈ B ∧ z = ⟨a, b⟩ by cart_prod.def;
                follows π₁(z) = a by opair_first.def given z = ⟨a, b⟩;
                done logically
                ;
            done logically
            ;
        hence (∀y, y ∈ ran(R) → y ∈ B) as
            arbitrary y;
            assume y ∈ ran(R) then y ∈ B as
                obtain z st z ∈ R ∧ y = π₂(z) by ran.def;
                follows z ∈ A × B by sub.def given R ⊆ A × B;
                obtain b st b ∈ B and a st a ∈ A ∧ z = ⟨a, b⟩ by cart_prod.def;
                follows π₂(z) = b by opair_second.def given z = ⟨a, b⟩;
                done logically
                ;
            done logically
            ;
        done logically
    ;
    -- (←)
    assume ((∃C, ∃D, R ∈ Rel(C, D)) ∧ dom(R) ⊆ A ∧ ran(R) ⊆ B) then R ∈ Rel(A, B) as
        hence R : Rel by rel.is_rel_on;
        follows R ∈ Rel(dom(R), ran(R)) by rel.def;
        thus R ⊆ dom(R) × ran(R) by rel_on.def;
        -- TODO: is this lemma useful?
        follows dom(R) × ran(R) ⊆ A × B by cart_prod.sub;
        hence R ⊆ A × B by sub.def given R ⊆ dom(R) × ran(R);
        done by rel_on.def
        ;
    done logically
qed

A functional relation is a particular kind of binary relation where the first 
element of each ordered pair in the relation is unique.

notation functional_relation
    term ::= term " → " term
end

definition
    A → B := {f ∈ Rel(A, B) | ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f}
end

theorem fn_on.def [A B : term] :
    |- ∀f, f ∈ (A → B) ↔ f ∈ Rel(A, B) ∧ ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f
proof
    suffices ∀f, f ∈ {f ∈ Rel(A, B) | ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f} ↔ f ∈ Rel(A, B) ∧ ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f;
    done by zfc.extensionality
qed

And once again we can define the notion of being a function independent of the
domain and range.

definition
    f : Fn := f ∈ (dom(f) → ran(f))
end

theorem fn.def [f : term] :
    |- f : Fn ↔ f ∈ (dom(f) → ran(f))
proof
    done by iff.refl [f : Fn]
qed

lemma fn.in_rel [A B : term] :
    |- (A → B) ⊆ Rel(A, B)
proof
    thus {f ∈ Rel(A, B) | ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f} ⊆ Rel(A, B)
        by comp.sub [∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ _] [Rel(A, B)];
qed

theorem fn.is_fn_on [f : term] :
    |- f : Fn ↔ ∃A, ∃B, f ∈ (A → B)
proof
    suffices f ∈ (dom(f) → ran(f)) ↔ ∃A, ∃B, f ∈ (A → B);
    assume f ∈ (dom(f) → ran(f)) then ∃A, ∃B, f ∈ (A → B) logically;
    assume ∃A, ∃B, f ∈ (A → B) then f ∈ (dom(f) → ran(f)) as
        obtain A st ∃B, f ∈ (A → B) logically;
        obtain B st f ∈ (A → B) logically;
        hence f ∈ Rel(A, B) ∧ ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f by fn_on.def;
        follows f : Rel by rel.is_rel_on;
        follows f ∈ Rel(dom(f), ran(f)) by rel.def;
        follows dom(f) ⊆ A by rel_on.is_rel;
        follows ∀a, a ∈ dom(f) → a ∈ A by sub.def given dom(f) ⊆ A;
        hence ∀a ∈ dom(f), ∃!b, ⟨a, b⟩ ∈ f logically;
        done by fn_on.def
        ;
    done logically
qed

theorem fn_on.is_fn [f A B : term] :
    |- f ∈ (A → B) ↔ (f : Fn ∧ dom(f) = A ∧ ran(f) ⊆ B)
proof
    hence f: Fn ↔ ∃C, ∃D, f ∈ (C → D) by fn.is_fn_on;
    suffices f ∈ (A → B) ↔ (∃C, ∃D, f ∈ (C → D) ∧ dom(f) = A ∧ ran(f) ⊆ B) logically;
    assume f ∈ (A → B) then (∃C, ∃D, f ∈ (C → D) ∧ dom(f) = A ∧ ran(f) ⊆ B) as
        hence ∃C, ∃D, f ∈ (C → D) logically;
        thus ∀x, x ∈ (A → B) → ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ x by fn_on.def;
        follows ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f logically;
        suffices dom(f) = A ∧ ran(f) ⊆ B logically;
        follows (A → B) ⊆ Rel(A, B) by fn.in_rel;
        follows f ∈ Rel(A, B) by sub.def given (A → B) ⊆ Rel(A, B);
        follows dom(f) ⊆ A ∧ ran(f) ⊆ B by rel_on.is_rel;
        suffices A ⊆ dom(f) by sub.sub_eq;
        suffices ∀a ∈ A, a ∈ dom(f) by sub.def;
        arbitrary a;
        assume a ∈ A then a ∈ dom(f) as
            obtain b st ⟨a, b⟩ ∈ f logically;
            thus a = π₁(⟨a, b⟩) by opair_first.def;
            done by dom.def given ⟨a, b⟩ ∈ f
            ;
        done logically
        ;
    assume (∃C, ∃D, f ∈ (C → D) ∧ dom(f) = A ∧ ran(f) ⊆ B) then f ∈ (A → B) as
        obtain C st ∃D, f ∈ (C → D) ∧ dom(f) = A ∧ ran(f) ⊆ B logically;
        obtain D st f ∈ (C → D) ∧ dom(f) = A ∧ ran(f) ⊆ B logically;
        follows f : Fn by fn.is_fn_on;
        follows f ∈ (dom(f) → ran(f)) by fn.def;
        follows ∀a ∈ dom(f), ∃!b, ⟨a, b⟩ ∈ f by fn_on.def;
        hence ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f logically;
        follows (C → D) ⊆ Rel(C, D) by fn.in_rel;
        follows f ∈ Rel(C, D) by sub.def given (C → D) ⊆ Rel(C, D);
        follows f : Rel by rel.is_rel_on;
        hence dom(f) = A logically;
        follows dom(f) ⊆ dom(f) by sub.refl;
        follows dom(f) ⊆ A by eq.subst [dom(f) ⊆ _] [dom(f)] [A];
        follows f ∈ Rel(A, B) by rel_on.is_rel;
        done by fn_on.def
        ;
    done logically
qed

We define function application by extracting the second element of the unique 
ordered pair which has the argument as the first element. We can make this
 definition using the iota operator.

notation function_application
    term (1000) ::= term "(" term ")"
end

definition
    f:term (a) := ℩b, ⟨a, b⟩ ∈ f
end

This proof follows from our definition as well as the iota operator which lets us show unambiguity

theorem fn_on.pairs [f A B : term] : (f ∈ (A → B))
    |- f = {⟨a, f(a)⟩ | a ∈ A}
proof
    suffices f = {y | ∃a, a ∈ A ∧ y = ⟨a, f(a)⟩};
    thus f ∈ Rel(A, B) ∧ ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f by fn_on.def;
    follows f ⊆ A × B by rel_on.def;
    follows ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ f logically;
    thus ∀x, x ∈ f ↔ (∃a, a ∈ A ∧ x = ⟨a, f(a)⟩) as
        arbitrary x;
        assume x ∈ f then ∃a, a ∈ A ∧ x = ⟨a, f(a)⟩ as
            follows x ∈ A × B by sub.def given f ⊆ A × B;
            obtain a st a ∈ A and b st b ∈ B ∧ x = ⟨a, b⟩ by cart_prod.def;
            follows ⟨a, b⟩ ∈ f given x = ⟨a, b⟩;
            follows ∃!b, ⟨a, b⟩ ∈ f logically;
            follows ⟨a, f(a)⟩ ∈ f by iota.unique [⟨a, _⟩ ∈ f];
            hence f(a) = b logically;
            hence x = ⟨a, f(a)⟩ logically;
            done logically
            ;
        assume ∃a, a ∈ A ∧ x = ⟨a, f(a)⟩ then x ∈ f as
            obtain a st a ∈ A ∧ x = ⟨a, f(a)⟩ logically;
            follows ∃!b, ⟨a, b⟩ ∈ f logically;
            follows ⟨a, f(a)⟩ ∈ f by iota.unique [⟨a, _⟩ ∈ f];
            done logically
            ;
        done logically
        ;
    -- f itself witnesses that the set exists, so the comprehension is well
    -- defined and has the expected members.
    follows ∃z, ∀x, x ∈ z ↔ (∃a, a ∈ A ∧ x = ⟨a, f(a)⟩) logically;
    follows ∀x, x ∈ {y | ∃a, a ∈ A ∧ y = ⟨a, f(a)⟩} ↔ (∃a, a ∈ A ∧ x = ⟨a, f(a)⟩) by uncomp.def [∃a, a ∈ A ∧ _ = ⟨a, f(a)⟩];
    follows ∀x, x ∈ f ↔ x ∈ {y | ∃a, a ∈ A ∧ y = ⟨a, f(a)⟩} logically;
    done by zfc.extensionality
qed

theorem fn.pairs [f : term] : (f : Fn)
    |- f = {⟨x, f(x)⟩ | x ∈ dom(f)}
proof
    follows f ∈ (dom(f) → ran(f)) by fn.def;
    done by fn_on.pairs [f] [dom(f)] [ran(f)]
qed


notation function_maps_to
    term ::= x:@binding(term) " ∈ " term " ↦ " term(x)
end

definition
    x ∈ X ↦ f(x) := {⟨x, f(x)⟩ | x ∈ X}
end

This theorem follows from an ever-rare explicit use of the axiom of replacement as well as previously shown results for relations.

theorem fun_map.is.rel [A B : term] [f(_) : term(term)]: (∀x ∈ A, f(x) ∈ B)
    |- x ∈ A ↦ f(x) ∈ (A → B)
proof
    suffices {⟨x, f(x)⟩ | x ∈ A} ∈ (A → B);
    suffices {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} ∈ (A → B);
    -- Using our replacement axiom to show that a functional mapping of a set defines its own set
    follows ∀a, (∀x, x ∈ a → ∃!y, y = ⟨x, f(x)⟩) → (∃x, ∀y, y ∈ x ↔ (∃z, z ∈ a ∧ y = ⟨z, f(z)⟩))
        by zfc.replacement [_1 = ⟨_0, f(_0)⟩];
    -- Then we show the set that it defines
    follows ∃z, ∀y, y ∈ z ↔ (∃x, x ∈ A ∧ y = ⟨x, f(x)⟩) logically;
    thus ∀y, y ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} ↔ (∃x, x ∈ A ∧ y = ⟨x, f(x)⟩)
        by uncomp.def [∃x, x ∈ A ∧ _ = ⟨x, f(x)⟩];
    suffices {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} ∈ Rel(A, B)
        ∧ ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} by fn_on.def;
    -- Function mappings are subsets of all of the relations between two sets
    thus {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} ∈ Rel(A, B) as
        suffices {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} ⊆ A × B by rel_on.def;
        suffices ∀w, w ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} → w ∈ A × B by sub.def;
        arbitrary w;
        assume w ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} then w ∈ A × B as
            obtain a st a ∈ A ∧ w = ⟨a, f(a)⟩ logically;
            follows f(a) ∈ B logically;
            done by cart_prod.def
            ;
        done logically
        ;
    -- Showing function well-definedness, basically that every element a in A has a mapping, and that a = a → f(a) = f(a)
    thus ∀a ∈ A, ∃!b, ⟨a, b⟩ ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} as
        arbitrary a;
        assume a ∈ A then ∃!b, ⟨a, b⟩ ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} as
            thus ⟨a, f(a)⟩ ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} logically;
            thus ∀b, ⟨a, b⟩ ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} → b = f(a) as
                arbitrary b;
                assume ⟨a, b⟩ ∈ {y | ∃x, x ∈ A ∧ y = ⟨x, f(x)⟩} then b = f(a) as
                    obtain c st c ∈ A ∧ ⟨a, b⟩ = ⟨c, f(c)⟩ logically;
                    follows a = c ∧ b = f(c) by opair.eq;
                    done logically
                    ;
                done logically
                ;
            done logically
            ;
        done logically
        ;

    done logically
qed


