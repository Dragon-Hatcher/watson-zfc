theorem fn.restriction.eq [f g X : term] : (f : Fn) (g : Fn) (dom(f) ∩ X = dom(g) ∩ X)
    (∀x ∈ dom(f) ∩ X, f(x) = g(x))
    |- f ↾ X = g ↾ X
proof
    -- chain f ↾ X 
    --     = {⟨x, f(x)⟩ | x ∈ dom(f) ∩ X} by fn.restriction.pairs;
    --     = {⟨x, g(x)⟩ | x ∈ dom(f) ∩ X} given ∀x ∈ X, f(x) = g(x);
    --     = {⟨x, g(x)⟩ | x ∈ dom(g) ∩ X} given dom(f) ∩ X = dom(g) ∩ X;
    --     = g ↾ X                        by fn.restriction.pairs;
    chain f ↾ X 
        = {⟨x, f(x)⟩ | x ∈ dom(f) ∩ X} as todo;
        = {⟨x, g(x)⟩ | x ∈ dom(f) ∩ X} as todo;
        = {⟨x, g(x)⟩ | x ∈ dom(g) ∩ X} as todo;
        = g ↾ X                        as todo;
qed
